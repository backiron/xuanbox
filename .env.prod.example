DEBUG=false

POSTGRES_DB=xuanbox
POSTGRES_USER=xuanbox
POSTGRES_PASSWORD=change-this-postgres-password

JWT_SECRET_KEY=change-this-jwt-secret-at-least-32-characters
MASTER_KEY=change-this-master-key-at-least-24-characters

WEB_PORT=15173
API_PORT=18080
DROP_PUBLIC_ORIGIN=http://10.0.0.182:15173
CORS_ORIGINS=http://10.0.0.182:15173,http://localhost:15173,http://127.0.0.1:15173
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1|10\.\d{1,3}\.\d{1,3}\.\d{1,3}|172\.(1[6-9]|2\d|3[0-1])\.\d{1,3}\.\d{1,3}|192\.168\.\d{1,3}\.\d{1,3})(:\d+)?
VITE_API_BASE_URL=/api/v1

RECEIPT_AI_ASSIST_ENABLED=true
RECEIPT_AI_MODEL=qwen2.5:1.5b
RECEIPT_AI_BASE_URL=http://host.docker.internal:11434
DOCUMENT_AI_ENABLED=true
DOCUMENT_AI_MODEL=qwen2.5:1.5b
DOCUMENT_AI_BASE_URL=http://host.docker.internal:11434
DOCUMENT_AI_CONCURRENCY=1
BACKUP_SCHEDULE_HOURS=24
